#!/bin/bash
# Wrapper around `gh api` that authenticates as the lucos_agent GitHub App.
# Handles token generation internally — no need to manage tokens manually.
#
# Usage: gh-as-agent <gh api arguments>
# e.g.:  gh-as-agent repos/lucas42/lucos/issues --method POST -f title="..." -f body="..."

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOKEN=$("$SCRIPT_DIR/get-token")

gh api -H "Authorization: token $TOKEN" "$@"
