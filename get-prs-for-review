#!/bin/bash
# Returns a summary of all open pull requests across unarchived repositories owned by lucas42.
#
# Output: human-readable list grouped by repo, showing PR number, title, author, and URL.
#         Repos with no open PRs are silently skipped.
#         If there are no open PRs anywhere, a single "No open pull requests found." line is printed.
#
# Authentication: uses the lucos-code-reviewer GitHub App via get-token.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOKEN=$("$SCRIPT_DIR/get-token" --app "lucos-code-reviewer")

# Wrapper: call GitHub API authenticated as lucos-code-reviewer
gh_api() {
    gh api -H "Authorization: token $TOKEN" "$@"
}

# Fetch all unarchived repos owned by lucas42.
# The /users/{user}/repos endpoint returns all repos the token can see;
# we filter archived=false client-side since the API doesn't support that filter directly.
REPOS=$(gh_api --paginate /users/lucas42/repos --jq '.[] | select(.archived == false) | .full_name')

total_prs=0

while IFS= read -r REPO; do
    # Fetch open PRs for this repo. On error (e.g. no-PR access), treat as empty.
    REPO_PRS=$(gh_api --paginate \
        "/repos/${REPO}/pulls?state=open&per_page=100" \
        --jq '.[]' 2>/dev/null || true)

    if [[ -z "$REPO_PRS" ]]; then
        continue
    fi

    # Count PRs in this repo
    PR_COUNT=$(echo "$REPO_PRS" | jq -s 'length')
    total_prs=$((total_prs + PR_COUNT))

    echo "=== ${REPO} (${PR_COUNT} open PR$([ "$PR_COUNT" -eq 1 ] && echo "" || echo "s")) ==="

    # Print each PR on a pair of lines: number/title/author, then URL
    echo "$REPO_PRS" | jq -r '
        "#\(.number) \(.title) [by \(.user.login)]\n  \(.html_url)"
    '

    echo ""

done <<< "$REPOS"

if [[ "$total_prs" -eq 0 ]]; then
    echo "No open pull requests found."
fi
