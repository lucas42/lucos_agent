#!/bin/bash
# Returns a JSON list of GitHub issues that need triage attention from lucos-issue-manager.
#
# Inclusion criteria (any one is sufficient):
#   1. Issues with no workflow labels — have never been triaged; need initial
#      triage. Workflow labels are: needs-refining, agent-approved, owner:*,
#      priority:*, status:*. Non-workflow labels like 'bug', 'enhancement',
#      'audit-finding' etc. do not count as triaged.
#   2. Issues labelled 'needs-refining' where the most recent comment is NOT
#      from lucos-issue-manager[bot] — an owner agent has probably completed
#      work and the issue needs a label transition.
#   2b. Issues labelled 'needs-refining' where the most recent comment IS from
#       lucos-issue-manager[bot] but has reactions from a non-bot user — e.g.
#       a +1 on a proposal counts as new activity that needs re-triage.
#   3. Issues explicitly labelled 'owner:lucos-issue-manager' — the issue has
#      been routed directly back to the issue manager.
#   4. Issues with some workflow labels (owner:*, priority:*, or status:*) but
#      missing BOTH 'needs-refining' and 'agent-approved' — inconsistent label
#      state, probably left in limbo by a manual label adjustment.
#
# Exclusion criteria:
#   - Issues labelled 'agent-approved' (already done).
#   - Pull requests (GitHub's issues API includes PRs; filtered out).
#   - Archived repositories (no active work happening there).
#
# Output: JSON array of objects with keys: repo, number, title, url, labels
#
# Authentication: uses the lucos-issue-manager GitHub App via get-token.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOKEN=$("$SCRIPT_DIR/get-token" --app "lucos-issue-manager")

# Wrapper: call GitHub API authenticated as lucos-issue-manager
gh_api() {
    gh api -H "Authorization: token $TOKEN" "$@"
}

# Fetch all non-archived repos owned by lucas42
REPOS=$(gh_api --paginate /users/lucas42/repos --jq '.[] | select(.archived == false) | .full_name')

issues_json="[]"

while IFS= read -r REPO; do
    # Fetch all open issues for this repo, excluding pull requests.
    # We fetch everything and filter client-side to apply the label logic below.
    REPO_ISSUES=$(gh_api --paginate \
        "/repos/${REPO}/issues?state=open&per_page=100" \
        --jq '[.[] | select(.pull_request == null)]' 2>/dev/null || echo "[]")

    # Process each issue
    while IFS= read -r ISSUE; do
        NUMBER=$(echo "$ISSUE" | jq -r '.number')
        TITLE=$(echo "$ISSUE" | jq -r '.title')
        URL=$(echo "$ISSUE" | jq -r '.html_url')
        LABELS=$(echo "$ISSUE" | jq -r '[.labels[].name]')
        LABEL_COUNT=$(echo "$LABELS" | jq 'length')

        # Always exclude issues labelled 'agent-approved'
        IS_AGENT_APPROVED=$(echo "$LABELS" | jq -r 'map(select(. == "agent-approved")) | length > 0')
        if [[ "$IS_AGENT_APPROVED" == "true" ]]; then
            continue
        fi

        INCLUDE="false"

        # Criterion 1: Issues with no workflow labels need initial triage.
        # Workflow labels are: needs-refining, agent-approved, owner:*, priority:*, status:*
        # Non-workflow labels (bug, enhancement, audit-finding, etc.) don't count.
        WORKFLOW_LABEL_COUNT=$(echo "$LABELS" | jq '[.[] | select(
            . == "needs-refining" or
            . == "agent-approved" or
            startswith("owner:") or
            startswith("priority:") or
            startswith("status:")
        )] | length')
        if [[ "$WORKFLOW_LABEL_COUNT" -eq 0 ]]; then
            INCLUDE="true"
        fi

        # Criterion 2: 'needs-refining' issues where the last commenter is not us
        if [[ "$INCLUDE" == "false" ]]; then
            IS_NEEDS_REFINING=$(echo "$LABELS" | jq -r 'map(select(. == "needs-refining")) | length > 0')
            if [[ "$IS_NEEDS_REFINING" == "true" ]]; then
                COMMENTS=$(gh_api --paginate \
                    "/repos/${REPO}/issues/${NUMBER}/comments?per_page=100" \
                    --jq '.' 2>/dev/null || echo "[]")

                COMMENT_COUNT=$(echo "$COMMENTS" | jq 'length')
                if [[ "$COMMENT_COUNT" -eq 0 ]]; then
                    # No comments yet — include for initial triage
                    INCLUDE="true"
                else
                    LAST_COMMENT=$(echo "$COMMENTS" | jq '.[-1]')
                    LAST_COMMENTER=$(echo "$LAST_COMMENT" | jq -r '.user.login')
                    if [[ "$LAST_COMMENTER" != "lucos-issue-manager[bot]" ]]; then
                        # Someone else acted last — needs a triage pass
                        INCLUDE="true"
                    else
                        # Last comment is ours — check if any comment in the
                        # thread has reactions from a non-bot user (e.g. a +1
                        # on a proposal from another agent).
                        TOTAL_REACTIONS=$(echo "$COMMENTS" | jq '[.[].reactions.total_count] | add')
                        if [[ "$TOTAL_REACTIONS" -gt 0 ]]; then
                            # At least one comment has reactions — fetch details
                            # for comments that have them and check for non-bot reactors.
                            REACTED_IDS=$(echo "$COMMENTS" | jq -r '.[] | select(.reactions.total_count > 0) | .id')
                            while IFS= read -r CID; do
                                REACTORS=$(gh_api \
                                    "/repos/${REPO}/issues/comments/${CID}/reactions" \
                                    --jq '[.[].user.login | select(endswith("[bot]") | not)]' 2>/dev/null || echo "[]")
                                if [[ $(echo "$REACTORS" | jq 'length') -gt 0 ]]; then
                                    INCLUDE="true"
                                    break
                                fi
                            done <<< "$REACTED_IDS"
                        fi
                    fi
                fi
            fi
        fi

        # Criterion 3: Explicitly routed to lucos-issue-manager
        if [[ "$INCLUDE" == "false" ]]; then
            IS_OWNER_ISSUE_MANAGER=$(echo "$LABELS" | jq -r 'map(select(. == "owner:lucos-issue-manager")) | length > 0')
            if [[ "$IS_OWNER_ISSUE_MANAGER" == "true" ]]; then
                INCLUDE="true"
            fi
        fi

        # Criterion 4: Has some workflow labels but is missing both 'needs-refining'
        # and 'agent-approved' — inconsistent state left by a manual label adjustment.
        # (Criterion 1 already catches issues with NO workflow labels; this catches
        # issues that have some but are in an ambiguous in-between state.)
        if [[ "$INCLUDE" == "false" ]]; then
            HAS_OWNER_OR_PRIORITY_OR_STATUS=$(echo "$LABELS" | jq -r '[.[] | select(
                startswith("owner:") or
                startswith("priority:") or
                startswith("status:")
            )] | length > 0')
            HAS_NEEDS_REFINING=$(echo "$LABELS" | jq -r 'map(select(. == "needs-refining")) | length > 0')
            if [[ "$HAS_OWNER_OR_PRIORITY_OR_STATUS" == "true" && "$HAS_NEEDS_REFINING" == "false" ]]; then
                INCLUDE="true"
            fi
        fi

        if [[ "$INCLUDE" == "false" ]]; then
            continue
        fi

        # Append this issue to the results
        ISSUE_ENTRY=$(jq -n \
            --arg repo "$REPO" \
            --argjson number "$NUMBER" \
            --arg title "$TITLE" \
            --arg url "$URL" \
            --argjson labels "$LABELS" \
            '{repo: $repo, number: $number, title: $title, url: $url, labels: $labels}')

        issues_json=$(echo "$issues_json" | jq --argjson entry "$ISSUE_ENTRY" '. + [$entry]')

    done < <(echo "$REPO_ISSUES" | jq -c '.[]' 2>/dev/null || true)

done <<< "$REPOS"

# Also include issues in the "Needs Triage" column of the project board.
# (Status option ID: d5369b39)
# These may not yet have workflow labels, so the label-based logic above may
# not have caught them. We merge and deduplicate by URL.
# The board may have 200+ items, so we paginate until hasNextPage is false.
BOARD_ISSUES=$(GH_PROJECTS="$SCRIPT_DIR/gh-projects" python3 << 'PYEOF'
import json, os, subprocess, sys

gh_projects = os.environ["GH_PROJECTS"]

QUERY_TEMPLATE = """
{
  node(id: "PVT_kwHOAAaLL84BRh5d") {
    ... on ProjectV2 {
      items(first: 100%s) {
        pageInfo { hasNextPage endCursor }
        nodes {
          content {
            ... on Issue {
              number
              title
              url
              repository { nameWithOwner }
              labels(first: 20) { nodes { name } }
            }
          }
          fieldValues(first: 10) {
            nodes {
              ... on ProjectV2ItemFieldSingleSelectValue {
                name
                field { ... on ProjectV2SingleSelectField { name } }
              }
            }
          }
        }
      }
    }
  }
}
"""

all_nodes = []
cursor = None

while True:
    after_arg = f', after: "{cursor}"' if cursor else ""
    query = QUERY_TEMPLATE % after_arg
    result = subprocess.run(
        [gh_projects, "graphql", "-f", f"query={query}"],
        capture_output=True, text=True, check=True
    )
    data = json.loads(result.stdout)
    items = data["data"]["node"]["items"]
    all_nodes.extend(items["nodes"])
    if not items["pageInfo"]["hasNextPage"]:
        break
    cursor = items["pageInfo"]["endCursor"]

results = []
for node in all_nodes:
    content = node.get("content")
    if not content or "url" not in content:
        continue
    fields = {
        fv["field"]["name"]: fv["name"]
        for fv in node.get("fieldValues", {}).get("nodes", [])
        if fv and "field" in fv
    }
    if fields.get("Status") != "Needs Triage":
        continue
    labels = [l["name"] for l in content.get("labels", {}).get("nodes", [])]
    results.append({
        "repo":   content["repository"]["nameWithOwner"],
        "number": content["number"],
        "title":  content["title"],
        "url":    content["url"],
        "labels": labels,
    })

print(json.dumps(results))
PYEOF
)

# Merge board issues into issues_json, deduplicating by URL
issues_json=$(echo "$issues_json" | jq \
    --argjson board "$BOARD_ISSUES" \
    'reduce $board[] as $item (
        .;
        if any(.[]; .url == $item.url) then . else . + [$item] end
    )')

echo "$issues_json"
