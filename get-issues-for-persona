#!/bin/bash
# Returns a filtered list of open GitHub issues labeled with the given persona
# as the owner.
#
# The owner label convention is: owner:<persona-name>
# (e.g. "owner:lucos-system-administrator")
#
# Usage: get-issues-for-persona <--review|--implement> <persona-name>
#   e.g. get-issues-for-persona --review lucos-system-administrator
#        get-issues-for-persona --implement lucos-developer
#
# Modes (exactly one required):
#   --review     Return only needs-refining issues for this persona.
#                These are issues needing design input, specialist review,
#                or discussion -- not code changes.
#
#   --implement  Return only the single highest-priority agent-approved,
#                non-blocked issue for this persona.  This is the next
#                issue the persona should write code for.
#
# The two modes return non-overlapping sets of issues, determined entirely
# by the issue's labels.
#
# Filtering:
#   --review:    includes only issues with 'needs-refining' label
#   --implement: includes only issues with 'agent-approved' label;
#                excludes issues with 'status:blocked' label;
#                returns at most one issue (highest priority, oldest first)
#
# Sorting (both modes):
#   - priority:high first, then priority:medium, then priority:low, then
#     unprioritised issues last.
#   - Within each priority band, oldest issues first.
#
# Output: human-readable list grouped by repo, showing issue number, title,
#         and URL.  Repos with no matching issues are silently skipped.
#         If there are no matching issues, a single informational line is
#         printed.
#
# Authentication: uses the named persona's own GitHub App credentials via
#                 get-token.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PERSONAS_FILE="$SCRIPT_DIR/personas.json"

MODE=""

# Parse flags
while [[ $# -gt 0 ]]; do
    case "$1" in
        --review)
            MODE="review"
            shift
            ;;
        --implement)
            MODE="implement"
            shift
            ;;
        --next)
            # Backward compatibility: --next is equivalent to --implement
            MODE="implement"
            shift
            ;;
        -*)
            echo "Unknown flag: $1" >&2
            echo "Usage: $(basename "$0") <--review|--implement> <persona-name>" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

# Require exactly one positional argument after flags
if [[ $# -ne 1 ]]; then
    echo "Usage: $(basename "$0") <--review|--implement> <persona-name>" >&2
    echo "  e.g. $(basename "$0") --review lucos-system-administrator" >&2
    echo "       $(basename "$0") --implement lucos-developer" >&2
    exit 1
fi

if [[ -z "$MODE" ]]; then
    echo "Error: must specify either --review or --implement" >&2
    echo "Usage: $(basename "$0") <--review|--implement> <persona-name>" >&2
    exit 1
fi

PERSONA="$1"

# Validate the persona exists in personas.json
VALID=$(python3 -c "
import json, sys
with open('$PERSONAS_FILE') as f:
    personas = json.load(f)
if '$PERSONA' not in personas:
    valid = ', '.join(sorted(personas.keys()))
    print(f'Error: Unknown persona \\'$PERSONA\\'. Valid options: {valid}', file=sys.stderr)
    sys.exit(1)
print('ok')
")

if [[ "$VALID" != "ok" ]]; then
    exit 1
fi

OWNER_LABEL="owner:${PERSONA}"

TOKEN=$("$SCRIPT_DIR/get-token" --app "$PERSONA")

# Wrapper: call GitHub API authenticated as the given persona
gh_api() {
    gh api -H "Authorization: token $TOKEN" "$@"
}

# Fetch all unarchived repos owned by lucas42.
REPOS=$(gh_api --paginate /users/lucas42/repos --jq '.[] | select(.archived == false) | .full_name')

# Collect all matching issues into a temp file as a JSON array for sorting.
# Each issue is annotated with the repo name.
TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

echo "[]" > "$TMPFILE"

while IFS= read -r REPO; do
    # Fetch open issues for this repo with the owner label.
    # GitHub's issues API includes PRs; filter them out by excluding anything
    # with a pull_request field.
    REPO_ISSUES=$(gh_api --paginate \
        "/repos/${REPO}/issues?state=open&labels=$(python3 -c "import urllib.parse; print(urllib.parse.quote('${OWNER_LABEL}'))")&per_page=100" \
        --jq '[.[] | select(.pull_request == null)]' 2>/dev/null || echo "[]")

    ISSUE_COUNT=$(echo "$REPO_ISSUES" | jq 'length')

    if [[ "$ISSUE_COUNT" -eq 0 ]]; then
        continue
    fi

    # Annotate each issue with its repo name, then append to the accumulated list
    ANNOTATED=$(echo "$REPO_ISSUES" | jq --arg repo "$REPO" '[.[] | . + {_repo: $repo}]')
    jq --argjson new "$ANNOTATED" '. + $new' "$TMPFILE" > "${TMPFILE}.new"
    mv "${TMPFILE}.new" "$TMPFILE"

done <<< "$REPOS"

# Sort, filter, and format using Python (reads JSON from file, uses env vars for options)
_GET_ISSUES_MODE="$MODE" \
_GET_ISSUES_OWNER_LABEL="$OWNER_LABEL" \
_GET_ISSUES_TMPFILE="$TMPFILE" \
python3 << 'PYEOF'
import json
import sys
import os

tmpfile = os.environ["_GET_ISSUES_TMPFILE"]
mode = os.environ.get("_GET_ISSUES_MODE", "")
owner_label = os.environ.get("_GET_ISSUES_OWNER_LABEL", "")

with open(tmpfile) as f:
    all_issues = json.load(f)

PRIORITY_ORDER = {
    "priority:high": 0,
    "priority:medium": 1,
    "priority:low": 2,
}
UNPRIORITISED = 3

def get_label_names(issue):
    return [l["name"] for l in issue.get("labels", [])]

def sort_key(issue):
    label_names = get_label_names(issue)
    priority = UNPRIORITISED
    for p, rank in PRIORITY_ORDER.items():
        if p in label_names:
            priority = rank
            break
    # created_at is ISO8601 — lexicographic sort is correct for oldest-first
    return (priority, issue.get("created_at", ""))

# Filter based on mode
filtered = []
for issue in all_issues:
    label_names = get_label_names(issue)

    if mode == "review":
        # Only include needs-refining issues
        if "needs-refining" not in label_names:
            continue
    elif mode == "implement":
        # Only include agent-approved, non-blocked issues
        if "agent-approved" not in label_names:
            continue
        if "status:blocked" in label_names:
            continue

    filtered.append(issue)

filtered.sort(key=sort_key)

if not filtered:
    if mode == "review":
        print(f"No needs-refining issues found with label '{owner_label}'.")
    elif mode == "implement":
        print(f"No implementable issues found with label '{owner_label}'.")
    sys.exit(0)

if mode == "implement":
    # Return only the single highest-priority issue
    issue = filtered[0]
    print(f"#{issue['number']} {issue['title']}")
    print(f"  {issue['html_url']}")
    sys.exit(0)

# Human-readable output grouped by repo, preserving priority-sorted order
current_repo = None
repo_issues = []

def flush_repo(repo, issues):
    if not issues:
        return
    count = len(issues)
    print(f"=== {repo} ({count} issue{'s' if count != 1 else ''}) ===")
    for issue in issues:
        print(f"#{issue['number']} {issue['title']}")
        print(f"  {issue['html_url']}")
    print()

for issue in filtered:
    repo = issue["_repo"]
    if repo != current_repo:
        flush_repo(current_repo, repo_issues)
        current_repo = repo
        repo_issues = []
    repo_issues.append(issue)

flush_repo(current_repo, repo_issues)

PYEOF
