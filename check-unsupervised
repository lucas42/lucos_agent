#!/bin/bash
# check-unsupervised <system-name>
# Queries the configy API and prints whether unsupervisedAgentCode is set for the given system.
# Exit code: 0 if YES, 1 if NO, 2 on error (system not found, API unreachable, etc.)

set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: check-unsupervised <system-name>" >&2
    exit 2
fi

SYSTEM="$1"
API_URL="https://configy.l42.eu/systems"

curl -sL "$API_URL" | python3 -c "
import json, sys

system = sys.argv[1]
try:
    data = json.load(sys.stdin)
except json.JSONDecodeError as e:
    print(f'ERROR: could not parse configy API response: {e}', file=sys.stderr)
    sys.exit(2)

match = next((s for s in data if s.get('id') == system), None)

if match is None:
    print(f\"ERROR: system '{system}' not found in configy\", file=sys.stderr)
    sys.exit(2)

val = match.get('unsupervisedAgentCode', False)
if val:
    print(f'{system}: unsupervisedAgentCode = YES')
    sys.exit(0)
else:
    print(f'{system}: unsupervisedAgentCode = NO')
    sys.exit(1)
" "$SYSTEM"
