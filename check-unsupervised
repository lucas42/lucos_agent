#!/bin/bash
# check-unsupervised <repo-name>
# Queries the configy API (systems, components, and scripts) and prints whether
# unsupervisedAgentCode is set for the given repo.
# Exit code: 0 if YES, 1 if NO, 2 on error (not found in any endpoint, API unreachable, etc.)

set -euo pipefail

if [ $# -ne 1 ]; then
    echo "Usage: check-unsupervised <repo-name>" >&2
    exit 2
fi

SYSTEM="$1"
BASE_URL="https://configy.l42.eu"

python3 -c "
import json, sys, urllib.request

system = sys.argv[1]
base_url = sys.argv[2]
endpoints = ['systems', 'components', 'scripts']
all_entries = []

for endpoint in endpoints:
    try:
        with urllib.request.urlopen(f'{base_url}/{endpoint}') as resp:
            data = json.load(resp)
            if isinstance(data, list):
                all_entries.extend(data)
    except Exception as e:
        print(f'ERROR: could not fetch {endpoint}: {e}', file=sys.stderr)
        sys.exit(2)

match = next((s for s in all_entries if s.get('id') == system), None)

if match is None:
    print(f\"ERROR: '{system}' not found in configy (checked systems, components, scripts)\", file=sys.stderr)
    sys.exit(2)

val = match.get('unsupervisedAgentCode', False)
if val:
    print(f'{system}: unsupervisedAgentCode = YES')
    sys.exit(0)
else:
    print(f'{system}: unsupervisedAgentCode = NO')
    sys.exit(1)
" "$SYSTEM" "$BASE_URL"
