#!/bin/bash
# Returns the next implementable issue from the implementation queue.
#
# The queue is defined in docs/implementation-queue.txt in the lucos repo
# (at ~/sandboxes/lucos/docs/implementation-queue.txt). Issues are listed
# top-to-bottom; the first valid issue is returned.
#
# An issue is valid if it is:
#   - listed in the queue file
#   - open on GitHub
#   - labelled 'agent-approved'
#   - NOT labelled 'status:blocked'
#   - has an 'owner:*' label
#   - is not a pull request
#
# Malformed lines (not matching the GitHub issue URL pattern) are silently skipped.
#
# Output: If an issue is found, prints three lines:
#   Line 1: owner label (e.g. "owner:lucos-developer")
#   Line 2: issue title prefixed with number (e.g. "#42 Fix the thing")
#   Line 3: issue URL (e.g. "https://github.com/lucas42/lucos_photos/issues/42")
#
# If no implementable issue is found, prints an informational message and
# exits with code 0.
#
# Authentication: uses lucos-issue-manager app credentials (read-only issue access).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QUEUE_FILE="$HOME/sandboxes/lucos/docs/implementation-queue.txt"

TOKEN=$("$SCRIPT_DIR/get-token" --app lucos-issue-manager)

# Wrapper: call GitHub API authenticated as lucos-issue-manager
gh_api() {
    gh api -H "Authorization: token $TOKEN" "$@"
}

if [[ ! -f "$QUEUE_FILE" ]]; then
    echo "Queue file not found: $QUEUE_FILE"
    exit 1
fi

# Read the queue file, skip blank lines and comments, yield issue URLs
while IFS= read -r line; do
    # Trim leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"

    # Skip blank lines and comments
    [[ -z "$line" ]] && continue
    [[ "$line" == \#* ]] && continue

    # Validate it looks like a GitHub issue URL (basic check)
    if ! [[ "$line" =~ ^https://github\.com/[^/]+/[^/]+/issues/[0-9]+$ ]]; then
        # Malformed line — skip silently
        continue
    fi

    # Extract owner/repo/number from URL
    # e.g. https://github.com/lucas42/lucos_photos/issues/42
    #        -> owner=lucas42, repo=lucos_photos, number=42
    REPO_PATH=$(echo "$line" | sed 's|https://github\.com/||' | sed 's|/issues/.*||')
    NUMBER=$(echo "$line" | sed 's|.*/issues/||')

    # Fetch issue details
    ISSUE=$(gh_api "/repos/${REPO_PATH}/issues/${NUMBER}" 2>/dev/null || true)

    if [[ -z "$ISSUE" ]]; then
        continue
    fi

    # Parse with Python: check all conditions and extract fields
    RESULT=$(echo "$ISSUE" | python3 -c "
import json, sys

issue = json.load(sys.stdin)

# Must be open
if issue.get('state') != 'open':
    sys.exit(1)

# Must not be a pull request
if issue.get('pull_request') is not None:
    sys.exit(1)

label_names = [l['name'] for l in issue.get('labels', [])]

# Must have agent-approved
if 'agent-approved' not in label_names:
    sys.exit(1)

# Must not be blocked
if 'status:blocked' in label_names:
    sys.exit(1)

# Must have an owner label
owner = next((l for l in label_names if l.startswith('owner:')), None)
if owner is None:
    sys.exit(1)

print(owner)
print(f\"#{issue['number']} {issue['title']}\")
print(issue['html_url'])
" 2>/dev/null) || true

    if [[ -n "$RESULT" ]]; then
        echo "$RESULT"
        exit 0
    fi

done < "$QUEUE_FILE"

echo "No implementable issues found in the queue."
