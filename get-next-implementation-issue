#!/bin/bash
# Returns the single highest-priority issue in the "Ready" column of the
# "lucOS Issue Prioritisation" GitHub v2 project board.
#
# Unlike the old label-scanning approach, this reads directly from the
# project board, which is the canonical source of truth for prioritisation.
#
# Usage: get-next-implementation-issue
#
# Filtering:
#   - Only items with Status = "Ready" (option ID: bfb298e3)
#   - Only items with an Owner (board field, or owner:* issue label as fallback)
#   - Only Issue content (not pull requests or draft issues)
#
# Sorting:
#   - Board position order (manual drag order on the project board)
#   - This takes full precedence — priority labels are not used for sorting
#
# Output: If an issue is found, prints three lines:
#   Line 1: owner label (e.g. "owner:lucos-developer")
#   Line 2: issue title prefixed with number (e.g. "#42 Fix the thing")
#   Line 3: issue URL (e.g. "https://github.com/lucas42/lucos_photos/issues/42")
#
# If no implementable issue is found, prints an informational message and
# exits with code 0.
#
# Authentication: uses gh-projects (GITHUB_PROJECTS_PAT) — GitHub Apps cannot
# access v2 user projects.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Fetch all project items in one query (project has <100 items, no pagination needed)
TMPFILE=$(mktemp)
trap 'rm -f "$TMPFILE"' EXIT

"$SCRIPT_DIR/gh-projects" graphql -f query='
{
  node(id: "PVT_kwHOAAaLL84BRh5d") {
    ... on ProjectV2 {
      items(first: 100, orderBy: {field: POSITION, direction: ASC}) {
        nodes {
          content {
            ... on Issue {
              number
              title
              url
              labels(first: 10) { nodes { name } }
            }
          }
          fieldValues(first: 10) {
            nodes {
              ... on ProjectV2ItemFieldSingleSelectValue {
                name
                field { ... on ProjectV2SingleSelectField { name } }
              }
            }
          }
        }
      }
    }
  }
}' > "$TMPFILE"

_TMPFILE="$TMPFILE" python3 << 'PYEOF'
import json
import os
import sys

with open(os.environ["_TMPFILE"]) as f:
    data = json.load(f)
nodes = data["data"]["node"]["items"]["nodes"]

def get_field_values(node):
    """Return a dict of field name -> option name for single-select fields."""
    result = {}
    for fv in node.get("fieldValues", {}).get("nodes", []):
        if fv and "field" in fv and "name" in fv:
            result[fv["field"]["name"]] = fv["name"]
    return result

# Items are returned in board position order (ASC) by the API query.
# We preserve that order — the first matching item is the highest priority.
ready_issues = []
for node in nodes:
    content = node.get("content")
    # Skip non-Issue items (draft issues have no 'url', PRs won't appear here)
    if not content or "url" not in content:
        continue

    fields = get_field_values(node)

    if fields.get("Status") != "Ready":
        continue

    owner_name = fields.get("Owner")
    if not owner_name:
        # Fall back to owner:* label on the issue itself
        labels = [l["name"] for l in content.get("labels", {}).get("nodes", [])]
        owner_labels = [l for l in labels if l.startswith("owner:")]
        if owner_labels:
            owner_name = owner_labels[0].removeprefix("owner:")
    if not owner_name:
        continue

    ready_issues.append({
        "number":     content["number"],
        "title":      content["title"],
        "url":        content["url"],
        "owner":      owner_name,
    })

if not ready_issues:
    print("No implementable issues found in the Ready column.")
    sys.exit(0)

issue = ready_issues[0]
print(f"owner:{issue['owner']}")
print(f"#{issue['number']} {issue['title']}")
print(issue["url"])

PYEOF
