#!/bin/bash
# Generates a GitHub App installation access token.
# The token is printed to stdout and is valid for 1 hour.
# Requires a .env file (from lucos_creds) in the same directory as this script.
#
# Usage: get-token [--app <app_name>]
#   app_name: lucos-agent (default) | lucos-issue-manager | lucos-code-reviewer

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

# Parse --app flag
APP_NAME="lucos-agent"
if [[ "${1:-}" == "--app" ]]; then
    APP_NAME="${2:?--app requires an argument}"
    shift 2
fi

case "$APP_NAME" in
    lucos-agent)
        APP_ID="2943201"
        INSTALLATION_ID="112266755"
        PEM_VAR="LUCOS_AGENT_PEM"
        ;;
    lucos-issue-manager)
        APP_ID="2952357"
        INSTALLATION_ID="112520892"
        PEM_VAR="LUCOS_ISSUE_MANAGER_PEM"
        ;;
    lucos-code-reviewer)
        APP_ID="2956131"
        INSTALLATION_ID="112629982"
        PEM_VAR="LUCOS_CODE_REVIEWER_PEM"
        ;;
    *)
        echo "Error: Unknown app '$APP_NAME'. Valid options: lucos-agent, lucos-issue-manager, lucos-code-reviewer" >&2
        exit 1
        ;;
esac

if [[ ! -f "$ENV_FILE" ]]; then
    echo "Error: .env file not found at $ENV_FILE" >&2
    exit 1
fi

# Extract PEM from .env and restore newlines.
# lucos_creds flattens the key to a single line with spaces; base64 content
# never contains spaces so replacing all spaces with newlines is safe.
PEM_KEY=$(python3 -c "
import re, sys
with open('$ENV_FILE') as f:
    content = f.read()
match = re.search(r'${PEM_VAR}=\"(.*?)\"', content, re.DOTALL)
if not match:
    print('Error: ${PEM_VAR} not found in .env', file=sys.stderr)
    sys.exit(1)
val = match.group(1)
# lucos_creds flattens newlines to spaces; the header/footer contain spaces
# too, so we parse them out, fix only the body, then reassemble.
import re as re2
m = re2.search(r'(-----BEGIN RSA PRIVATE KEY-----)(.*?)(-----END RSA PRIVATE KEY-----)', val, re2.DOTALL)
body = m.group(2).strip().replace(' ', '\n')
print(f'{m.group(1)}\n{body}\n{m.group(3)}')
")

# Base64url encode (no padding)
b64url() {
    openssl base64 -e | tr -d '=' | tr '+/' '-_' | tr -d '\n'
}

# Build JWT
NOW=$(date +%s)
IAT=$((NOW - 60))
EXP=$((NOW + 600))

TMPKEY=$(mktemp)
trap "rm -f $TMPKEY" EXIT
echo "$PEM_KEY" > "$TMPKEY"

HEADER=$(echo -n '{"alg":"RS256","typ":"JWT"}' | b64url)
PAYLOAD=$(echo -n "{\"iat\":${IAT},\"exp\":${EXP},\"iss\":\"${APP_ID}\"}" | b64url)
SIGNATURE=$(echo -n "${HEADER}.${PAYLOAD}" | openssl dgst -sha256 -sign "$TMPKEY" | b64url)
JWT="${HEADER}.${PAYLOAD}.${SIGNATURE}"

# Exchange JWT for an installation access token
curl -s -X POST \
    -H "Authorization: Bearer ${JWT}" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    "https://api.github.com/app/installations/${INSTALLATION_ID}/access_tokens" \
    | python3 -c "import sys, json; print(json.load(sys.stdin)['token'])"
